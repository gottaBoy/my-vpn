# NetBird self-hosted environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  SECURITY: This file is a template. Never commit .env or real secrets.
#     Generate all passwords with:  openssl rand -base64 24

# === Public domain (required) ===
# Must resolve to this server's IP.
# macOS test:  netbird.local  (add to /etc/hosts: 127.0.0.1 netbird.local)
# Production:  netbird.yourcompany.com
NETBIRD_DOMAIN=netbird.local

# === NetBird version (management + signal) ===
# Pinned to a specific release for stability.
# See: https://github.com/netbirdio/netbird/releases
NETBIRD_VERSION=0.72.1

# === Docker images (override for air-gapped / mirror) ===
# All images use MY_ prefix. Override to pin or use a private registry.
# management & signal version is controlled by NETBIRD_VERSION above.
HARBOR_REGISTRY=harbor.yourcompany.com
MY_POSTGRES_IMAGE=${HARBOR_REGISTRY}/library/postgres:16-alpine
MY_ZITADEL_IMAGE=${HARBOR_REGISTRY}/library/zitadel:latest
MY_ZITADEL_LOGIN_IMAGE=${HARBOR_REGISTRY}/library/zitadel-login:latest
MY_MANAGEMENT_IMAGE=${HARBOR_REGISTRY}/library/management:${NETBIRD_VERSION:-latest}
MY_SIGNAL_IMAGE=${HARBOR_REGISTRY}/library/signal:${NETBIRD_VERSION:-latest}
MY_COTURN_IMAGE=${HARBOR_REGISTRY}/library/coturn:4.6-alpine
MY_DASHBOARD_IMAGE=${HARBOR_REGISTRY}/library/dashboard:latest
MY_CADDY_IMAGE=${HARBOR_REGISTRY}/library/caddy:2-alpine

# === Coturn TURN/STUN ===
# Auth password (generate: openssl rand -base64 32)
TURN_PASSWORD=change-me-turn-password
# External IP for TURN/STUN (public IP of this host)
# Local: 127.0.0.1
# Production: EC2 EIP
TURN_EXTERNAL_IP=127.0.0.1

# === PostgreSQL ===
# Host for Zitadel config (defaults to local postgres container)
POSTGRES_HOST=postgres
POSTGRES_USER=netbird
# Local: uses docker-compose postgres container, password below
# Production: AWS RDS endpoint, set NETBIRD_RDS_DSN instead (see below)
POSTGRES_PASSWORD=change-me-postgres-password

# === Production only: RDS DSN ===
# When set, the local postgres container is disabled (docker-compose.prod.yaml).
# NETBIRD_RDS_DSN=postgres://netbird:${POSTGRES_PASSWORD}@rds-xxx.xxx.rds.amazonaws.com:5432/netbird?sslmode=require

# === Zitadel IdP ===
# Master key (MUST be exactly 32 bytes)
# Generate: openssl rand -base64 32 | head -c 32
ZITADEL_MASTERKEY=change-me-masterkey-32bytes
# Admin user password (Dashboard / Zitadel Console first login)
# Username: netbird-admin  →  full login: netbird-admin@${NETBIRD_DOMAIN}
# ⚠️  MUST include: uppercase, lowercase, digit, AND symbol (e.g. !@#$)
# Generate: openssl rand -base64 18 | tr -dc 'A-Za-z0-9!@#$' | head -c 16
ZITADEL_ADMIN_PASSWORD=change-me-must-have-symbol!123
# External port Zitadel uses in OIDC URLs (8443 for test, 443 for prod)
ZITADEL_EXTERNALPORT=8443

# === NetBird Management ===
# Datastore encryption key (32 bytes base64)
# Generate: openssl rand -base64 32
NB_DATASTORE_ENCRYPTION_KEY=change-me-encryption-key-base64

# --- PKI (TLS certificates) ---
# For local test: cert-export.sh pulls from K8s Secret (needs kubectl)
# For ECS/production: place your TLS cert+key in ./certs/ manually:
#   ./certs/tls.crt   — server certificate (full chain)
#   ./certs/tls.key   — private key
#   chmod 600 certs/tls.key
DASHBOARD_CLIENT_ID=376492196917948418