# NetBird self-hosted environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# === Public domain (required) ===
# Must resolve to this server's IP.
# macOS test:  netbird.local  (add to /etc/hosts: 127.0.0.1 netbird.local)
# Production:  netbird.yourcompany.com
NETBIRD_DOMAIN=netbird.local

# === Coturn TURN/STUN ===
# Auth password (generate: openssl rand -base64 32)
TURN_PASSWORD=change-me-to-a-random-string
# External IP for TURN/STUN (public IP of this host)
# Local: 127.0.0.1
# Production: EC2 EIP
TURN_EXTERNAL_IP=127.0.0.1

# === PostgreSQL ===
# Local: uses docker-compose postgres container, password below
# Production: AWS RDS endpoint, set NETBIRD_RDS_DSN instead (see below)
POSTGRES_PASSWORD=netbird

# === Production only: RDS DSN ===
# When set, the local postgres container is disabled (docker-compose.prod.yaml).
# NETBIRD_RDS_DSN=postgres://netbird:${POSTGRES_PASSWORD}@rds-xxx.xxx.rds.amazonaws.com:5432/netbird?sslmode=require

# === Zitadel IdP ===
# Master key (generate: openssl rand -base64 32)
ZITADEL_MASTERKEY=MasterkeyForDevOnly
# Admin password for Dashboard first login
ZITADEL_ADMIN_PASSWORD=NetBirdAdmin123!

# --- PKI integration (cert-manager → local files) ---
# These paths are populated by cert-export.sh / cert-renew-cron.sh from the K8s Secret:
#   ./certs/tls.crt   — server certificate (full chain)
#   ./certs/tls.key   — private key
