{
    "_comment": "This is a template. Run auto-init.sh to generate the real management.json.",
    "DataStoreEncryptionKey": "<generated-by-auto-init>",
    "HttpConfig": {
        "Address": "0.0.0.0:443",
        "CertFile": "/etc/netbird/tls.crt",
        "CertKey": "/etc/netbird/tls.key",
        "AuthIssuer": "https://<your-domain>",
        "AuthAudience": "<dashboard-client-id>",
        "OIDCConfigEndpoint": "https://<your-domain>/.well-known/openid-configuration",
        "IdpSignKeyRefreshEnabled": true
    },
    "IdpManagerConfig": {
        "ManagerType": "zitadel",
        "ClientConfig": {
            "Issuer": "https://<your-domain>",
            "TokenEndpoint": "https://<your-domain>/oauth/v2/token",
            "ClientID": "<sa-client-id>",
            "ClientSecret": "<sa-client-secret>",
            "GrantType": "client_credentials"
        },
        "ExtraConfig": {
            "ManagementEndpoint": "https://<your-domain>/management/v1"
        }
    },
    "DeviceAuthorizationFlow": {
        "Provider": "hosted",
        "ProviderConfig": {
            "Audience": "<cli-client-id>",
            "ClientID": "<cli-client-id>",
            "Scope": "openid"
        }
    },
    "PKCEAuthorizationFlow": {
        "ProviderConfig": {
            "Audience": "<cli-client-id>",
            "ClientID": "<cli-client-id>",
            "Scope": "openid profile email offline_access",
            "RedirectURLs": [
                "http://localhost:53000/",
                "http://localhost:54000/"
            ]
        }
    },
    "StoreConfig": {
        "Engine": "postgres"
    },
    "Signal": {
        "Proto": "http",
        "URI": "<your-domain>:10000"
    }
}
